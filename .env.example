# =============================================================================
# AI TV Stack secrets
# =============================================================================
# 1. Copy this file to .env in THIS SAME FOLDER:
#      cp .env.example .env
#    2. Fill in your real keys (never commit .env — it is gitignored)
#
# All stack scripts load secrets from AI_TV_ORCHESTRATION/.env first, then fall
# back to /root/.env or /workspace/.env for older pods.
# =============================================================================

# --- GitHub (clone PRIVATE FluxRT + stack scripts; push patches) ---
# Classic PAT with "repo" scope, or fine-grained read on both private repos
# https://github.com/settings/tokens
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUXRT_REPO=gschian0/FluxRT
STACK_SCRIPTS_REPO=gschian0/ai-tv-stack-scripts
VENDOR_BRANCH=5090-runpod

# --- Hugging Face (FLUX + MusicGen model downloads) ---
# https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- NVIDIA (Magpie quote TTS via Riva + DiffusionGemma quote generation) ---
# https://build.nvidia.com/ — API key for integrate.api.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Gemini (optional — future prompt / quote / caption plugins) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Twitch live broadcast ---
# Twitch dashboard → Settings → Stream → Primary Stream key
TWITCH_STREAM_KEY=live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- ngrok free tier: ONE API key + ONE cloud endpoint from the dashboard ---
# Create both once at https://dashboard.ngrok.com — reuse on every pod.
#
# API key (REST — scripts use this to configure your endpoint):
NGROK_APIKEY=
#
# Agent authtoken (local ngrok binary). Leave blank on first run;
# start_ngrok_gradio.sh creates one from NGROK_APIKEY and saves it here.
NGROK_AUTHTOKEN=
#
# Cloud endpoint you created on ngrok.com (stable public HTTPS URL):
NGROK_ENDPOINT_URL=https://your-subdomain.ngrok-free.dev
NGROK_ENDPOINT_ID=ep_xxxxxxxxxxxxxxxxxx
