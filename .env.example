# Copy to /root/.env or /workspace/.env and fill in values.
# Never commit the real .env file.

# --- Model & platform keys ---
GITHUB_PAT=ghp_xxxxxxxxxxxx
HF_TOKEN=hf_xxxxxxxxxxxx
TWITCH_STREAM_KEY=live_xxxxxxxxxxxx
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxx

# --- ngrok remote access (Gradio on your phone) ---
# Get your API key: https://dashboard.ngrok.com/api-keys
NGROK_APIKEY=your_ngrok_api_key_here

# Agent authtoken — optional if using start_ngrok_gradio.sh (created from API key).
# Or copy directly: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Cloud endpoint created in ngrok dashboard (stable public HTTPS URL).
NGROK_ENDPOINT_URL=https://your-subdomain.ngrok-free.dev
NGROK_ENDPOINT_ID=ep_xxxxxxxxxxxx
